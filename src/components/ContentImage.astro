---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  remote?: boolean;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
}

const {
  src,
  alt,
  remote = false,
  class: className,
  width,
  height,
  widths,
  sizes,
  loading,
} = Astro.props;
---

{
  remote ? (
    <img
      class={className}
      src={src.src}
      alt={alt}
      width={width ?? src.width}
      height={height ?? src.height}
      loading={loading}
    />
  ) : (
    <Image
      class={className}
      src={src}
      alt={alt}
      width={width}
      height={height}
      widths={widths}
      sizes={sizes}
      loading={loading}
    />
  )
}
