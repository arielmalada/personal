---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string | ImageMetadata;
  remote: boolean;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
}

const props = Astro.props as Props;
const remoteSrc =
  props.remote && typeof props.src === 'string' ? props.src : undefined;
const localSrc =
  !props.remote && typeof props.src !== 'string' ? props.src : undefined;
---

{
  remoteSrc ? (
    <img
      class={props.class}
      src={remoteSrc}
      alt={props.alt}
      width={props.width}
      height={props.height}
      loading={props.loading}
    />
  ) : localSrc ? (
    <Image
      class={props.class}
      src={localSrc}
      alt={props.alt}
      width={props.width}
      height={props.height}
      widths={props.widths}
      sizes={props.sizes}
      loading={props.loading}
    />
  ) : null
}
