---
import { render } from 'astro:content';
import ContentImage from '../../components/ContentImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';
import { getBlogPosts } from '../../lib/content';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const entries = await getBlogPosts();
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(date);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishDate.toISOString(),
  dateModified: (
    entry.data.updatedDate ?? entry.data.publishDate
  ).toISOString(),
  url: Astro.url.href,
  author: { '@type': 'Person', name: SITE.title, url: Astro.site?.href },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogType="article"
  image={withBase(`/og/blog/${entry.id}.png`)}
  structuredData={articleSchema}
>
  <article data-pagefind-body>
    <header class="page-head section article-head">
      <p class="eyebrow">Blog</p>
      {
        entry.data.draft && import.meta.env.DEV && (
          <p class="draft-label">Local draft</p>
        )
      }
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
      <div class="entry-meta">
        <time datetime={entry.data.publishDate.toISOString()}
          >{formatDate(entry.data.publishDate)}</time
        >
        <span>{remarkPluginFrontmatter.minutesRead}</span>
        <span>{entry.data.tags.join(' / ')}</span>
      </div>
      {
        entry.data.heroImage && (
          <ContentImage
            class="article-image"
            src={entry.data.heroImage.src}
            alt=""
            remote={entry.data.heroImage.remote}
            widths={[720, 1040, 1400]}
            sizes="(min-width: 900px) 72rem, 100vw"
            loading="lazy"
          />
        )
      }
    </header>

    <div class="section article-layout">
      <aside class="article-toc" aria-label="Table of contents">
        <p class="eyebrow">Contents</p>
        <nav>
          {
            headings
              .filter((heading) => heading.depth === 2)
              .map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)
          }
        </nav>
      </aside>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
