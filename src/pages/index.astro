---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getBlogPosts, getWorkEntries } from '../lib/content';
import { withBase } from '../lib/url';

const works = (await getWorkEntries()).slice(0, 3);
const posts = (await getBlogPosts()).slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title="Ariel Malada"
  description="Frontend engineer focused on thoughtful interfaces, user experience, and the systems behind them."
>
  <section class="hero section">
    <p class="eyebrow">Frontend engineering / UX / writing</p>
    <h1>I build interfaces with the person using them in mind.</h1>
    <p class="lead">
      I am Ariel, a frontend engineer working across product interfaces, user
      experience, and the technical systems that keep both understandable.
    </p>
    <div class="action-row" aria-label="Primary links">
      <a class="button" href={withBase('/works/')}>View works</a>
      <a class="text-link" href={withBase('/blog/')}>Read notes</a>
    </div>
  </section>

  <section class="section split-overview" aria-label="Working principles">
    <div>
      <p class="eyebrow">How I work</p>
      <h2>Clarity before complexity.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Interfaces</h3>
        <p>
          Accessible, responsive experiences built around the task rather than
          the framework.
        </p>
      </article>
      <article>
        <h3>Systems</h3>
        <p>
          Reusable foundations that make product changes safer and easier to
          understand.
        </p>
      </article>
      <article>
        <h3>Curiosity</h3>
        <p>
          Research, prototypes, and honest evaluation before settling on an
          answer.
        </p>
      </article>
    </div>
  </section>

  <section class="section index-feed" aria-labelledby="latest-works">
    <div class="section-heading">
      <p class="eyebrow">Selected work</p>
      <h2 id="latest-works">Projects in context.</h2>
      <a class="text-link" href={withBase('/works/')}>All works</a>
    </div>

    {
      works.length > 0 ? (
        <div class="highlight-grid">
          {works.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>
                {work.data.draft && import.meta.env.DEV && (
                  <p class="draft-label">Draft</p>
                )}
                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>{work.data.title}</a>
                </h3>
                <p>{work.data.description}</p>
                {work.data.tech.length > 0 && (
                  <ul
                    class="tag-list"
                    aria-label={`${work.data.title} technology`}
                  >
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Case studies are being prepared for publication.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Writing</p>
      <h2 id="latest-notes">Notes from the work.</h2>
      <a class="text-link" href={withBase('/blog/')}>All posts</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>
                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>The first notes are still taking shape. Check back soon.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
